# MONGODB_URI: Connection string para MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<password>@cluster0.mongodb.net/cryptodash
MONGODB_URI="mongodb+srv://<user>:<pass>@cluster0.example.mongodb.net/cryptodash"

# JWT_SECRET: Clave secreta para firmar JSON Web Tokens
# Debe ser una cadena larga y aleatoria. Nunca compartas esto públicamente.
JWT_SECRET="your_super_secret_jwt_key_here"

# GEMINI_API_KEY: API key de Google Gemini para análisis con IA
# Se lee ÚNICAMENTE en el backend (geminiService.ts). NUNCA se expone al frontend.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: URL donde se aloja la aplicación
# En desarrollo: http://localhost:3000
# En Vercel: tu dominio asignado (ej: https://cryptodash.vercel.app)
APP_URL="http://localhost:3000"
